# Required: the shared password to enter the website
SITE_PASSWORD=your-secret-password-here

# Your GitHub usernames (for the Projects page)
GITHUB_USERNAME_1=your-github-username
GITHUB_USERNAME_2=partner-github-username

# Supabase — required for Places, Memories, and all shared data
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
